# ─────────────────────────────────────────────
# BidOps Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env or .env.local to git
# ─────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────
# Local dev (Docker Compose):
DATABASE_URL="postgresql://bidops:bidops_dev_password@localhost:5432/bidops_dev"
# Railway: postgresql://user:pass@host:5432/dbname
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── AUTH ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── SAM.GOV ──────────────────────────────────
# Get your key at: https://sam.gov/profile/details
SAM_GOV_API_KEY="your-sam-gov-api-key-here"

# ── ANTHROPIC / CLAUDE ───────────────────────
# Used by the agent layer (FastAPI / LangGraph)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# ── REDIS ────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── FILE STORAGE ─────────────────────────────
# Cloudflare R2 (recommended) or AWS S3
STORAGE_BUCKET="bidops-documents"
STORAGE_ENDPOINT="https://your-r2-account.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"

# ── ENCRYPTION (for portal credentials at rest) ──
# Generate: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY="generate-32-byte-hex-key"

# ── APP CONFIG ───────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3004"

# ── FASTAPI AGENT SERVICE ────────────────────
AGENT_API_URL="http://localhost:8000"
AGENT_API_SECRET="shared-secret-between-next-and-fastapi"

# ── PORTAL AUTH (password gate) ───────────────────────────────
# The password users type to access the portal
PORTAL_PASSWORD="choose-a-strong-password"
# A random token stored in the cookie — generate with:
# openssl rand -hex 32
PORTAL_AUTH_TOKEN="generate-32-byte-hex-token"

# ── PRODUCTION URLS ───────────────────────────────────────────
# Set these when deploying
NEXTAUTH_URL="https://app.southernshadetechnologies.com"
NEXT_PUBLIC_APP_URL="https://app.southernshadetechnologies.com"
AGENT_API_URL="https://your-api.railway.app"

# ── TENANT ────────────────────────────────────────────────────
# The UUID of the Southern Shade tenant row in the DB
# Get this after running the seed script
DEFAULT_TENANT_ID="paste-tenant-uuid-from-seed-output"
